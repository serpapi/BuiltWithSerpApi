---
layout: base.njk
title: "#BuiltWithSerpApi"
description: "Browse SerpApi powered apps, agents, dashboards, monitors, and experiments built by the community."
---

<section class="stream-section">
  <div class="shell stream-layout">
    <div class="rail-card intro-card">
      <p class="label">{% icon "feed" %}Community feed</p>
      <h1>#BuiltWithSerpApi</h1>
      <p>Browse SerpApi powered products, agents, dashboards, monitors, and experiments. Keep scrolling until an idea sticks.</p>
    </div>

    <div class="stream-body">
      <aside class="stream-rail">
      <div class="rail-card stat-card">
        <a href="{{ site.submitUrl }}" target="_blank" rel="noopener noreferrer">
          <span class="stat-icon">{% icon "spark" %}</span>
          <strong>{{ projects.length }}</strong>
          <span>projects to remix</span>
        </a>
        <a href="{{ '/apis/' | url }}">
          <span class="stat-icon">{% icon "hub" %}</span>
          <strong>{{ projects | allApis | length }}</strong>
          <span>SerpApi engines</span>
        </a>
        <a href="{{ '/tags/' | url }}">
          <span class="stat-icon">{% icon "tag" %}</span>
          <strong>{{ projects | allTags | length }}</strong>
          <span>idea tags</span>
        </a>
      </div>

      <div class="rail-card browse-card-rail">
        <h2>{% icon "search" %}Browse fast</h2>
        <div class="side-links">
          <a href="{{ '/tags/' | url }}"><span>{% icon "tag" %}All tags</span></a>
          <a href="{{ '/apis/' | url }}"><span>{% icon "api" %}All engines</span></a>
          <a href="{{ site.docs }}" target="_blank" rel="noopener noreferrer"><span>{% icon "book" %}SerpApi docs</span></a>
        </div>
      </div>

      <div class="rail-card submit-card">
        <h2>{% icon "add" %}Add a build</h2>
        <p>Got an app, automation, or prototype using SerpApi? Add it to the feed.</p>
        <a class="button" href="{{ site.submitUrl }}" target="_blank" rel="noopener noreferrer">{% icon "send" %}Submit project</a>
      </div>
      </aside>

      <div class="stream-main">
      <div class="stream-header">
        <div class="stream-heading-top">
          <p class="label">{% icon "spark" %}Idea stream</p>
          <a class="text-link" href="{{ site.docs }}" target="_blank" rel="noopener noreferrer">{% icon "globe" %}SerpApi docs</a>
        </div>
        <h2>Scroll through projects built on live search data.</h2>
      </div>

      <div class="feed stream-feed">
      {% set sdkPromoIndex = (projects.length / 4) | round %}
      {% set mcpPromoIndex = (projects.length / 2) | round %}
      {% set blogPromoIndex = (projects.length * 3 / 4) | round(0, "ceil") %}
      {% for project in projects %}
        {% include "project-card.njk" %}
        {% if loop.index == sdkPromoIndex %}
          <aside class="idea-break">
            <span>{% icon "code" %}SDK integrations</span>
            <strong>Use a language-specific SerpApi SDK to wire search data into your app faster.</strong>
            <p>Pick the integration path that matches your stack and skip the boilerplate around request setup, parsing, and examples.</p>
            <div class="idea-actions">
              <a href="https://serpapi.com/integrations?utm_source=builtwithserpapi" target="_blank" rel="noopener noreferrer">{% icon "docs" %}Browse integrations</a>
            </div>
          </aside>
        {% endif %}
        {% if loop.index == mcpPromoIndex %}
          <aside class="idea-break idea-break-mcp">
            <span>{% icon "hub" %}MCP server</span>
            <strong>Connect SerpApi search results to agents and MCP-compatible tools.</strong>
            <p>The official SerpApi MCP server gives builders a ready path from natural language workflows to live search data.</p>
            <div class="idea-actions">
              <a href="https://github.com/serpapi/serpapi-mcp" target="_blank" rel="noopener noreferrer">{% icon "github" %}View source</a>
              <a href="https://serpapi.com/blog/introducing-serpapis-mcp-server/?utm_source=builtwithserpapi" target="_blank" rel="noopener noreferrer">{% icon "book" %}Read launch post</a>
            </div>
          </aside>
        {% endif %}
        {% if loop.index == blogPromoIndex %}
          <aside class="idea-break">
            <span>{% icon "idea" %}More ideas</span>
            <strong>Browse the SerpApi blog for build ideas, tutorials, and API walkthroughs.</strong>
            <p>Use the examples as prompts for your next SerpApi powered app, automation, dashboard, or agent workflow.</p>
            <div class="idea-actions">
              <a href="https://serpapi.com/blog/?utm_source=builtwithserpapi" target="_blank" rel="noopener noreferrer">{% icon "book" %}Open blog</a>
            </div>
          </aside>
        {% endif %}
      {% endfor %}
      </div>

      <section class="api-idea-board">
        <div class="section-heading">
          <h2>Browse the raw ingredients</h2>
          <p>Jump from inspiration to the APIs behind each project style.</p>
        </div>
        <div class="mini-browse-grid">
          {% for api in apis %}
            <a class="mini-browse-card" href="{{ ('/apis/' + (api | slug) + '/') | url }}">
              <span class="mini-icon">{% icon "api" %}</span>
              <span>{{ api }}</span>
              <strong>{{ projects | relatedProjectCount(api, "apis") }} project{% if projects | relatedProjectCount(api, "apis") != 1 %}s{% endif %}</strong>
            </a>
          {% endfor %}
        </div>
      </section>
      </div>
    </div>
  </div>
</section>
